generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── EXISTING MODELS (with additions) ────────────────────────────────────────

model Customer {
  customer_id    Int      @id @default(autoincrement())
  email          String   @unique @db.VarChar(255)
  password_hash  String   @db.VarChar(255)
  first_name     String   @db.VarChar(100)
  last_name      String   @db.VarChar(100)
  phone          String?  @db.VarChar(20)
  loyalty_points Int      @default(0)
  created_at     DateTime @default(now()) @db.Timestamptz()

  cart                 Cart?
  orders               Order[]
  skin_profile         Skin_Profile?
  survey_responses     Survey_Response[]
  recommendations      Recommendation[]
  reviews              Review[]
  addresses            Address[]
  wishlist_items       WishlistItem[]
  loyalty_transactions LoyaltyTransaction[]
  coupon_usages        CouponUsage[]
  returns              Return[]
  reset_tokens         PasswordResetToken[]

  @@map("customers")
}

model Admin {
  admin_id      Int      @id @default(autoincrement())
  email         String   @unique @db.VarChar(255)
  password_hash String   @db.VarChar(255)
  first_name    String   @db.VarChar(100)
  last_name     String   @db.VarChar(100)
  role          String   @default("admin") @db.VarChar(50)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now()) @db.Timestamptz()

  audit_logs AuditLog[]
  blog_posts BlogPost[]

  @@map("admins")
}

model Category {
  category_id   Int       @id @default(autoincrement())
  category_name String    @db.VarChar(100)
  description   String?   @db.Text
  image_url     String?   @db.Text
  slug          String?   @unique @db.VarChar(120)
  products      Product[]

  @@map("categories")
}

model Product {
  product_id      Int     @id @default(autoincrement())
  product_name    String  @db.VarChar(200)
  description     String? @db.Text
  category_id     Int
  is_featured     Boolean @default(false)
  seo_title       String? @db.VarChar(200)
  seo_description String? @db.Text

  category            Category             @relation(fields: [category_id], references: [category_id])
  variants            Product_Variant[]
  images              Product_Images[]
  product_ingredients Product_Ingredient[]
  recommendations     Recommendation[]
  reviews             Review[]
  wishlist_items      WishlistItem[]
  flash_sale_items    FlashSaleItem[]

  @@map("products")
}

model Product_Variant {
  variant_id          Int     @id @default(autoincrement())
  product_id          Int
  size                String? @db.VarChar(50)
  price               Decimal @db.Decimal(10, 2)
  stock               Int     @default(0) @map("stock_qty")
  low_stock_threshold Int     @default(10)

  product     Product      @relation(fields: [product_id], references: [product_id], onDelete: Cascade)
  cart_items  Cart_Item[]
  order_items Order_Item[]

  @@map("product_variants")
}

model Product_Images {
  image_id   Int     @id @default(autoincrement())
  product_id Int
  image_url  String  @db.Text
  is_primary Boolean @default(false)

  product Product @relation(fields: [product_id], references: [product_id], onDelete: Cascade)

  @@map("product_images")
}

model Cart {
  cart_id     Int      @id @default(autoincrement())
  customer_id Int      @unique
  created_at  DateTime @default(now()) @db.Timestamptz()

  customer Customer   @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)
  items    Cart_Item[]

  @@map("carts")
}

model Cart_Item {
  cart_item_id Int      @id @default(autoincrement())
  cart_id      Int
  variant_id   Int
  quantity     Int      @default(1)
  added_at     DateTime @default(now()) @db.Timestamptz()

  cart    Cart            @relation(fields: [cart_id], references: [cart_id], onDelete: Cascade)
  variant Product_Variant @relation(fields: [variant_id], references: [variant_id], onDelete: Cascade)

  @@unique([cart_id, variant_id])
  @@map("cart_items")
}

model Order {
  order_id      Int      @id @default(autoincrement())
  customer_id   Int
  order_ref     String   @unique @default(uuid()) @db.Uuid
  status        String   @default("pending") @db.VarChar(50)
  subtotal      Decimal  @db.Decimal(10, 2)
  tax           Decimal  @map("tax_amount") @db.Decimal(10, 2)
  shipping      Decimal  @map("shipping_cost") @db.Decimal(10, 2)
  discount      Decimal  @default(0) @map("discount_amount") @db.Decimal(10, 2)
  total         Decimal  @map("total_amount") @db.Decimal(10, 2)
  coupon_id     Int?
  created_at    DateTime @default(now()) @db.Timestamptz()

  customer       Customer    @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)
  items          Order_Item[]
  payment        Payment?
  ship           Ship?
  delivery       Delivery?
  coupon         Coupon?     @relation(fields: [coupon_id], references: [coupon_id])
  return_request Return?

  @@index([customer_id])
  @@index([status])
  @@map("orders")
}

model Order_Item {
  order_item_id     Int      @id @default(autoincrement())
  order_id          Int
  variant_id        Int
  quantity          Int?
  price_at_purchase Decimal? @db.Decimal(10, 2)

  order        Order           @relation(fields: [order_id], references: [order_id], onDelete: Cascade)
  variant      Product_Variant @relation(fields: [variant_id], references: [variant_id])
  return_items ReturnItem[]

  @@map("order_items")
}

model Payment {
  payment_id       Int      @id @default(autoincrement())
  order_id         Int      @unique
  stripe_intent_id String   @unique @db.VarChar(255)
  amount           Decimal  @db.Decimal(10, 2)
  status           String   @default("pending") @db.VarChar(50)
  created_at       DateTime @default(now()) @db.Timestamptz()

  order Order @relation(fields: [order_id], references: [order_id], onDelete: Cascade)

  @@map("payments")
}

model Skin_Profile {
  profile_id        Int      @id @default(autoincrement())
  customer_id       Int      @unique
  skin_type         String   @db.VarChar(50)
  concerns          String[] @db.Text
  sensitivity_level String   @db.VarChar(50)
  climate           String   @db.VarChar(50)
  created_at        DateTime @default(now()) @db.Timestamptz()
  updated_at        DateTime @updatedAt @db.Timestamptz()

  customer Customer @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)

  @@map("skin_profiles")
}

model Survey {
  survey_id  Int      @id @default(autoincrement())
  title      String   @db.VarChar(200)
  is_active  Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz()

  questions Survey_Question[]

  @@map("surveys")
}

model Survey_Question {
  question_id   Int      @id @default(autoincrement())
  survey_id     Int
  question_text String   @db.Text
  question_type String   @db.VarChar(50)
  options       String[] @db.Text
  mapping_key   String?  @db.VarChar(50)

  survey    Survey            @relation(fields: [survey_id], references: [survey_id], onDelete: Cascade)
  responses Survey_Response[]

  @@map("survey_questions")
}

model Survey_Response {
  response_id  Int      @id @default(autoincrement())
  customer_id  Int
  question_id  Int
  answer_value String   @db.Text
  created_at   DateTime @default(now()) @db.Timestamptz()

  customer Customer         @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)
  question Survey_Question  @relation(fields: [question_id], references: [question_id], onDelete: Cascade)

  @@map("survey_responses")
}

model Ingredient {
  ingredient_id Int    @id @default(autoincrement())
  name          String @unique @db.VarChar(100)
  description   String? @db.Text
  benefits      String? @db.Text
  concerns      String? @db.Text
  skin_types    String[] @db.Text

  product_ingredients Product_Ingredient[]

  @@map("ingredients")
}

model Product_Ingredient {
  product_ingredient_id Int @id @default(autoincrement())
  product_id            Int
  ingredient_id         Int

  product    Product    @relation(fields: [product_id], references: [product_id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredient_id], references: [ingredient_id], onDelete: Cascade)

  @@unique([product_id, ingredient_id])
  @@map("product_ingredients")
}

model Recommendation {
  recommendation_id Int      @id @default(autoincrement())
  customer_id       Int
  product_id        Int
  match_score       Int      @default(0)
  reason            String?  @db.Text
  created_at        DateTime @default(now()) @db.Timestamptz()

  customer Customer @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)
  product  Product  @relation(fields: [product_id], references: [product_id], onDelete: Cascade)

  @@unique([customer_id, product_id])
  @@map("recommendations")
}

model Review {
  review_id  Int      @id @default(autoincrement())
  customer_id Int
  product_id  Int
  rating      Int
  comment     String?  @db.Text
  created_at  DateTime @default(now()) @db.Timestamptz()

  customer Customer @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)
  product  Product  @relation(fields: [product_id], references: [product_id], onDelete: Cascade)

  @@unique([customer_id, product_id])
  @@index([product_id])
  @@map("reviews")
}

model Delivery_Partner {
  partner_id   Int     @id @default(autoincrement())
  name         String  @db.VarChar(100)
  contact_info String? @db.Text
  is_active    Boolean @default(true)

  ships Ship[]

  @@map("delivery_partners")
}

model Ship {
  ship_id      Int       @id @default(autoincrement())
  order_id     Int       @unique
  partner_id   Int
  tracking_num String    @unique @db.VarChar(100)
  shipped_at   DateTime  @default(now()) @db.Timestamptz()
  est_delivery DateTime? @db.Timestamptz()

  order   Order            @relation(fields: [order_id], references: [order_id], onDelete: Cascade)
  partner Delivery_Partner @relation(fields: [partner_id], references: [partner_id])

  @@map("ships")
}

model Delivery {
  delivery_id  Int       @id @default(autoincrement())
  order_id     Int       @unique
  ship_id      Int       @unique
  status       String    @default("out_for_delivery") @db.VarChar(50)
  delivered_at DateTime? @db.Timestamptz()
  notes        String?   @db.Text
  created_at   DateTime  @default(now()) @db.Timestamptz()

  order Order @relation(fields: [order_id], references: [order_id], onDelete: Cascade)

  @@map("deliveries")
}

model Address {
  address_id     Int      @id @default(autoincrement())
  customer_id    Int
  street_address String   @db.VarChar(255)
  city           String   @db.VarChar(100)
  state          String   @db.VarChar(100)
  zip_code       String   @db.VarChar(20)
  country        String   @db.VarChar(100)
  phone          String?  @db.VarChar(20)
  is_default     Boolean  @default(false)
  created_at     DateTime @default(now()) @db.Timestamptz()
  updated_at     DateTime @updatedAt @db.Timestamptz()

  customer Customer @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)

  @@index([customer_id])
  @@map("addresses")
}

// ─── NEW MODELS ───────────────────────────────────────────────────────────────

model PasswordResetToken {
  token_id    Int      @id @default(autoincrement())
  customer_id Int
  token       String   @unique @db.VarChar(255)
  expires_at  DateTime @db.Timestamptz()
  used        Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz()

  customer Customer @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model WishlistItem {
  wishlist_item_id Int      @id @default(autoincrement())
  customer_id      Int
  product_id       Int
  added_at         DateTime @default(now()) @db.Timestamptz()

  customer Customer @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)
  product  Product  @relation(fields: [product_id], references: [product_id], onDelete: Cascade)

  @@unique([customer_id, product_id])
  @@map("wishlist_items")
}

model Coupon {
  coupon_id        Int       @id @default(autoincrement())
  code             String    @unique @db.VarChar(50)
  description      String?   @db.Text
  discount_type    String    @db.VarChar(20) // "percentage" | "fixed"
  discount_value   Decimal   @db.Decimal(10, 2)
  min_order_amount Decimal?  @db.Decimal(10, 2)
  max_uses         Int?
  used_count       Int       @default(0)
  is_active        Boolean   @default(true)
  expires_at       DateTime? @db.Timestamptz()
  created_at       DateTime  @default(now()) @db.Timestamptz()

  orders CouponUsage[]
  Order  Order[]

  @@map("coupons")
}

model CouponUsage {
  usage_id    Int      @id @default(autoincrement())
  coupon_id   Int
  customer_id Int
  order_id    Int
  used_at     DateTime @default(now()) @db.Timestamptz()

  coupon   Coupon   @relation(fields: [coupon_id], references: [coupon_id], onDelete: Cascade)
  customer Customer @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)

  @@map("coupon_usages")
}

model FlashSale {
  flash_sale_id Int      @id @default(autoincrement())
  title         String   @db.VarChar(200)
  description   String?  @db.Text
  discount_pct  Int
  starts_at     DateTime @db.Timestamptz()
  ends_at       DateTime @db.Timestamptz()
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now()) @db.Timestamptz()

  items FlashSaleItem[]

  @@map("flash_sales")
}

model FlashSaleItem {
  item_id       Int @id @default(autoincrement())
  flash_sale_id Int
  product_id    Int

  flash_sale FlashSale @relation(fields: [flash_sale_id], references: [flash_sale_id], onDelete: Cascade)
  product    Product   @relation(fields: [product_id], references: [product_id], onDelete: Cascade)

  @@unique([flash_sale_id, product_id])
  @@map("flash_sale_items")
}

model Return {
  return_id     Int      @id @default(autoincrement())
  order_id      Int      @unique
  customer_id   Int
  reason        String   @db.Text
  status        String   @default("pending") @db.VarChar(50) // pending | approved | rejected | refunded
  refund_amount Decimal? @db.Decimal(10, 2)
  notes         String?  @db.Text
  created_at    DateTime @default(now()) @db.Timestamptz()
  updated_at    DateTime @updatedAt @db.Timestamptz()

  order    Order        @relation(fields: [order_id], references: [order_id], onDelete: Cascade)
  customer Customer     @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)
  items    ReturnItem[]

  @@map("returns")
}

model ReturnItem {
  return_item_id Int     @id @default(autoincrement())
  return_id      Int
  order_item_id  Int
  quantity       Int
  reason         String? @db.Text

  return_request Return     @relation(fields: [return_id], references: [return_id], onDelete: Cascade)
  order_item     Order_Item @relation(fields: [order_item_id], references: [order_item_id])

  @@map("return_items")
}

model CmsContent {
  content_id   Int      @id @default(autoincrement())
  key          String   @unique @db.VarChar(100)
  title        String?  @db.VarChar(200)
  content      String   @db.Text
  content_type String   @default("text") @db.VarChar(50) // "text" | "html" | "json"
  updated_at   DateTime @updatedAt @db.Timestamptz()

  @@map("cms_content")
}

model BlogPost {
  post_id      Int       @id @default(autoincrement())
  slug         String    @unique @db.VarChar(200)
  title        String    @db.VarChar(200)
  excerpt      String?   @db.Text
  content      String    @db.Text
  cover_image  String?   @db.Text
  author_id    Int?
  is_published Boolean   @default(false)
  seo_title    String?   @db.VarChar(200)
  seo_desc     String?   @db.Text
  published_at DateTime? @db.Timestamptz()
  created_at   DateTime  @default(now()) @db.Timestamptz()
  updated_at   DateTime  @updatedAt @db.Timestamptz()

  author Admin? @relation(fields: [author_id], references: [admin_id])

  @@map("blog_posts")
}

model Faq {
  faq_id     Int      @id @default(autoincrement())
  question   String   @db.Text
  answer     String   @db.Text
  category   String?  @db.VarChar(100)
  sort_order Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz()

  @@map("faqs")
}

model ContactMessage {
  message_id Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  email      String   @db.VarChar(255)
  subject    String   @db.VarChar(200)
  message    String   @db.Text
  status     String   @default("unread") @db.VarChar(50) // unread | read | responded
  created_at DateTime @default(now()) @db.Timestamptz()

  @@map("contact_messages")
}

model ShippingRule {
  rule_id          Int      @id @default(autoincrement())
  name             String   @db.VarChar(100)
  country          String?  @db.VarChar(100)
  min_order_amount Decimal? @db.Decimal(10, 2)
  flat_rate        Decimal  @db.Decimal(10, 2)
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now()) @db.Timestamptz()

  @@map("shipping_rules")
}

model StoreSettings {
  setting_id Int      @id @default(autoincrement())
  key        String   @unique @db.VarChar(100)
  value      String   @db.Text
  updated_at DateTime @updatedAt @db.Timestamptz()

  @@map("store_settings")
}

model AuditLog {
  log_id     Int      @id @default(autoincrement())
  admin_id   Int?
  action     String   @db.VarChar(100)
  entity     String   @db.VarChar(100)
  entity_id  String?  @db.VarChar(100)
  details    String?  @db.Text
  ip_address String?  @db.VarChar(50)
  created_at DateTime @default(now()) @db.Timestamptz()

  admin Admin? @relation(fields: [admin_id], references: [admin_id])

  @@index([admin_id])
  @@index([entity])
  @@map("audit_logs")
}

model LoyaltyTransaction {
  transaction_id Int      @id @default(autoincrement())
  customer_id    Int
  points         Int
  type           String   @db.VarChar(50) // "earned" | "redeemed" | "admin_adjustment" | "expired"
  description    String?  @db.Text
  order_id       Int?
  created_at     DateTime @default(now()) @db.Timestamptz()

  customer Customer @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)

  @@map("loyalty_transactions")
}
